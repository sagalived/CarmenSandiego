{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/main.jsx",
    "src/App.jsx",
    "src/componentes/páginas/Home.jsx",
    "src/componentes/holograma/**/*",
    "server/**/*.js",
    "src/test/**/*",
    "vite.config.js",
    "vitest.config.js"
  ],
  "exclude": ["node_modules", "dist"]
} 